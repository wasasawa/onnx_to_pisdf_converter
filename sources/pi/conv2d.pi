            </loop>
            <port kind="cfg_input" name="depthOutput" />
            <port kind="cfg_input" name="depthInput" />
            <port kind="cfg_input" name="sizeKernelHeight" />
            <port kind="cfg_input" name="sizeKernelWidth" />
