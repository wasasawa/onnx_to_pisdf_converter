            <port annotation="NONE" expr="depthOutput * outputHeight * outputWidth" kind="input" name="output_0" />
        </node>
        <node id="conv2d_neuron" kind="actor">
            <data key="graph_desc">Code/include/conv2d.h</data>
            <loop name="conv2d_neuron">
                <param direction="IN" isConfig="true" name="depthOutput" type="int" />
