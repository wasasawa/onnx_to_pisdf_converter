            <port kind="cfg_input" name="padBottom" />
            <port kind="cfg_input" name="padRight" />
            <port kind="cfg_input" name="outputHeight" />
            <port kind="cfg_input" name="outputWidth" />
            <port annotation="NONE" expr="inputHeight * inputWidth" kind="input" name="input_0" />
            <port annotation="NONE" expr="outputHeight * outputWidth" kind="output" name="output_0" />
        </node>
        <edge kind="fifo" type="float" source="input_0" sourceport="input_0" target="maxpool2d_neuron" targetport="input_0" />
        <edge kind="fifo" type="float" source="maxpool2d_neuron" sourceport="output_0" target="output_0" targetport="output_0" />
