<?xml version='1.0' encoding='UTF-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns">
    <graph edgedefault="directed">
        <data key="name">maxpool2d</data>
        <node id="depthInput" kind="cfg_in_iface" />
