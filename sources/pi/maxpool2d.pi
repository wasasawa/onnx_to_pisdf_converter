                <param direction="IN" isConfig="true" name="outputHeight" type="int" />
                <param direction="IN" isConfig="true" name="outputWidth" type="int" />
                <param direction="IN" isConfig="false" name="input_0" type="float" />
                <param direction="OUT" isConfig="false" name="output_0" type="float" />
            </loop>
            <port kind="cfg_input" name="depthInput" />
            <port kind="cfg_input" name="inputHeight" />
            <port kind="cfg_input" name="inputWidth" />
