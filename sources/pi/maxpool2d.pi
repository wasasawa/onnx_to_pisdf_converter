        </node>
        <node id="output_0" kind="snk">
            <port annotation="NONE" expr="depthInput * outputHeight * outputWidth" kind="input" name="output_0" />
        </node>
        <node id="maxpool2d_neuron" kind="actor">
            <data key="graph_desc">Code/include/maxpool2d.h</data>
            <loop name="maxpool2d_neuron">
                <param direction="IN" isConfig="true" name="depthInput" type="int" />
