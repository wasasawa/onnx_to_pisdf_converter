            <port kind="cfg_input" name="outputWidth" />
            <port annotation="NONE" expr="depthInput * inputHeight * inputWidth" kind="input" name="input_0" />
            <port annotation="NONE" expr="depthInput * sizeKernelHeight * sizeKernelWidth" kind="input" name="input_1" />
