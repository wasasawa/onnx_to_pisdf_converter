        <edge kind="fifo" type="float" source="input_0" sourceport="input_0" target="conv2d_neuron" targetport="input_0" />
        <edge kind="fifo" type="float" source="input_1" sourceport="input_1" target="conv2d_neuron" targetport="input_1" />
